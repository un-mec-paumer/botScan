generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  passwordHash  String?
  username      String?   @unique
  picture       Bytes?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLogin     DateTime?
  deletedAt     DateTime?

  AuthToken     AuthToken[]
  Alerts        Alert[]

  @@map("users")
}

model AuthToken {
  id               String   @id @default(uuid())
  userId           String
  refreshToken     String   @unique
  refreshExpiresAt DateTime
  revoked          Boolean  @default(false)
  createdAt        DateTime @default(now())
  userAgent        String?
  ipAddress        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

model work {
  id           Int     @id @default(autoincrement())
  name         String
  synopsis     String?
  imgUrl       String?
  
  mangaChapter String?
  
  animeSeason  String?
  animeEpisode String?

  Alerts       Alert[]
  mangaSources manga_source_works[]
  animeSources anime_source_works[]

  @@map("works")
}

model Alert {
  userId     String
  workId     Int
  mangaAlert Boolean @default(false)
  animeAlert Boolean @default(false)

  User       User    @relation(fields: [userId], references: [id])
  Work       work    @relation(fields: [workId], references: [id])

  @@id([userId, workId])
  @@map("alerts")
}

model anime_source {
    id     Int
    name  String

    @@id([id])
    animeSources anime_source_works[]
    @@map("anime_sources")
}

model manga_source {
    id     Int
    name  String

    @@id([id])
    mangaSources manga_source_works[]
    @@map("manga_sources")
}

model manga_source_works {
    mangaSourceId Int
    workId        Int

    mangaSource   manga_source @relation(fields: [mangaSourceId], references: [id])
    Work          work        @relation(fields: [workId], references: [id])

    @@id([mangaSourceId, workId])
    @@map("manga_source_works")
}

model anime_source_works {
    animeSourceId Int
    workId        Int

    animeSource   anime_source @relation(fields: [animeSourceId], references: [id])
    Work          work        @relation(fields: [workId], references: [id])

    @@id([animeSourceId, workId])
    @@map("anime_source_works")
}