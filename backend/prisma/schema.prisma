generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  passwordHash  String?
  username      String?   @unique
  picture       Bytes?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLogin     DateTime?
  deletedAt     DateTime?

  AuthToken     AuthToken[]
  Alerts        Alert[]

  @@map("users")
}

model AuthToken {
  id               String   @id @default(uuid())
  userId           String
  refreshToken     String   @unique
  refreshExpiresAt DateTime
  revoked          Boolean  @default(false)
  createdAt        DateTime @default(now())
  userAgent        String?
  ipAddress        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

model Work {
  id           Int     @id @default(autoincrement())
  name         String
  synopsis     String?
  imgUrl       String?
  mangaSource  String?
  mangaChapter String?
  animeSource  String?
  animeSeason  String?
  animeEpisode String?

  Alerts       Alert[]

  @@map("works")
}

model Alert {
  userId     String
  workId     Int
  mangaAlert Boolean @default(false)
  animeAlert Boolean @default(false)

  User       User    @relation(fields: [userId], references: [id])
  Work       Work    @relation(fields: [workId], references: [id])

  @@id([userId, workId])
  @@map("alerts")
}
